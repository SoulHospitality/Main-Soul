# =============================================================================
# Main Soul — environment template
# Copy to Server/.env
# =============================================================================

NODE_ENV=development
PORT=5000

# ── Required: Supabase Postgres connection (this is enough to run the app) ──
# Dashboard → Project Settings → Database → Connection string (URI)
# Prefer the "Session" pooler URI on port 5432 for migrations.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# App JWT (staff admin + local guest accounts)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Optional: Supabase Auth API (OTP / Apple / hosted auth) ──────────────────
# Leave blank if you only use DATABASE_URL. Guest email/password then uses
# local profiles + JWT stored in Postgres.
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=

# CORS / URLs
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173/admin
CORS_ORIGIN=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paymob
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_BASE_URL=https://accept.paymob.com/api

# Email (optional)
RESEND_API_KEY=
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=Soul Hospitality <noreply@soulhospitality.co>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

BOOKING_HOLD_MINUTES=30
BOOKING_HOLD_SWEEP_INTERVAL_MS=60000
CRON_SECRET=
PRICING_SYNC_SECRET=

# Optional — list images from a public Google Drive folder when saving a unit
# GOOGLE_API_KEY=
# GOOGLE_DRIVE_API_KEY=

# Seed staff (created on first boot if missing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123
ADMIN_EMAIL=admin@soulhospitality.co
